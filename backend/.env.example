# Server
PORT=3001
NODE_ENV=development

# PostgreSQL (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/asilia

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# Default admin (created on first boot if none exists)
ADMIN_EMAIL=mimeanidawa@gmail.com
ADMIN_PASSWORD=change-me-in-production

# Firebase Admin SDK — paste full service account JSON as a single line, or set path
# On Railway: add FIREBASE_SERVICE_ACCOUNT as a variable with the JSON content
FIREBASE_SERVICE_ACCOUNT=

# CORS — comma-separated origins (use * for dev only)
CORS_ORIGINS=*

# Aurax Pay — backend only; never expose these values in Flutter
PAYMENT_PROVIDER=aurax
AURAXPAY_BASE_URL=https://api.auraxpay.net/v1
AURAXPAY_API_KEY=
AURAXPAY_WEBHOOK_SECRET=
# Configure in Aurax Pay:
# https://your-api.example.com/api/payments/aurax/webhook
